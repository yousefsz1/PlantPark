{
  "expo": {
    "name": "Plant Park",
    "slug": "plant-park",
    "version": "1.0.0",
    "scheme": "plantpark",
    "orientation": "portrait",
    "icon": "./assets/icon-square.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.plantpark.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 1,
      "package": "com.plantpark.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Plant Park needs camera access to scan and identify your plants."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Plant Park needs photo library access so you can pick a plant photo to scan."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2ECC71",
          "sounds": []
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Plant Park uses calendar access to add optional watering reminders for your plants."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D2818",
          "image": "./assets/icon-square.png",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Plant Park uses your location to check local rainfall so it can skip watering reminders after it rains."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a01ef49a-5a61-4957-b4ba-9e18f4903125"
      }
    }
  }
}
