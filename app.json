{
  "expo": {
    "name": "PlantPal",
    "slug": "plantpal",
    "version": "1.0.0",
    "scheme": "plantpal",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D2818"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.plantpal.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D2818"
      },
      "package": "com.plantpal.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "PlantPal needs camera access to scan and identify your plants."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "PlantPal needs photo library access so you can pick a plant photo to scan."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2ECC71",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
